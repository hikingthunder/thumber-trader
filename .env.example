# ==============================
# Exchange / Product
# ==============================

# Set these to your Coinbase Advanced Trade credentials for live mode.
COINBASE_API_KEY=""
COINBASE_API_SECRET=""
PRODUCT_ID="BTC-USD"
PRODUCT_IDS="BTC-USD"

# ==============================
# Grid / Strategy
# ==============================
GRID_LINES="8"
GRID_BAND_PCT="0.15"
GRID_SPACING_MODE="arithmetic"
BASE_ORDER_NOTIONAL_USD="10"
HARD_STOP_LOSS_PCT="0.08"
ALPHA_FUSION_ENABLED="true"
ALPHA_WEIGHT_RSI="0.3"
ALPHA_WEIGHT_MACD="0.3"
ALPHA_WEIGHT_IMBALANCE="0.4"
VPIN_ENABLED="true"

# ==============================
# Execution / Runtime
# ==============================
PAPER_TRADING_MODE="true"
AUTO_START="true"
POLL_SECONDS="60"
LOG_LEVEL="INFO"

# ==============================
# Notifications
# ==============================
NOTIFICATIONS_ENABLED="true"
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
DISCORD_WEBHOOK_URL="discord_webhook"
SLACK_WEBHOOK_URL=""
PAGERDUTY_ROUTING_KEY=""

# ==============================
# Security / Auth
# ==============================
# Leave empty for a per-process ephemeral key, or set a long random value for persistent sessions.
JWT_SECRET_KEY=""
TRADINGVIEW_WEBHOOK_SECRET=""
SESSION_TIMEOUT_MINUTES="60"
# Comma-separated allowlist. Use explicit origins in production.
CORS_ALLOWED_ORIGINS="http://localhost:8080,http://127.0.0.1:8080"

# ==============================
# Persistence
# ==============================
STATE_DB_PATH="./thumber_trader.db"
TAX_LOT_METHOD="FIFO"

# Optional encryption key used by app/utils/helpers.py
APP_ENV_ENC_KEY=""
